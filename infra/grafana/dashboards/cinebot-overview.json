{
  "title": "CineBot — Service Overview",
  "uid": "cinebot-overview",
  "tags": ["cinebot", "api", "recommender"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "",
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests / sec (5m)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(cinebot_http_requests_total[5m]))", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 400 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "p95 latency (chat turn)",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(cinebot_recommendation_latency_seconds_bucket[5m])))",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.0 },
              { "color": "red", "value": 2.0 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "5xx rate (5m)",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(cinebot_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(cinebot_http_requests_total[5m]))",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "red", "value": 0.02 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Recommendations served (5m)",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(cinebot_recommendations_served_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "thresholds" } }
      }
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "HTTP latency percentiles",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(cinebot_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(cinebot_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(cinebot_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Requests by path",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "expr": "sum by (path) (rate(cinebot_http_requests_total[5m]))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },

    {
      "id": 20,
      "type": "timeseries",
      "title": "NLP stage latency (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (stage, le) (rate(cinebot_nlp_inference_seconds_bucket[5m])))",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "LLM latency (p95) + error rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(cinebot_llm_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 {{provider}}",
          "refId": "A"
        },
        {
          "expr": "sum by (provider) (rate(cinebot_llm_requests_total{outcome=\"failure\"}[5m]))",
          "legendFormat": "failures/s {{provider}}",
          "refId": "B"
        }
      ]
    },

    {
      "id": 30,
      "type": "timeseries",
      "title": "Feedback signals",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "targets": [
        {
          "expr": "sum by (signal) (rate(cinebot_feedback_total[5m]))",
          "legendFormat": "{{signal}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cps" } }
    },
    {
      "id": 31,
      "type": "stat",
      "title": "Like ratio (1h)",
      "description": "likes / (likes + dislikes) — proxy for recommendation quality",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "targets": [
        {
          "expr": "sum(increase(cinebot_feedback_total{signal=\"like\"}[1h])) / (sum(increase(cinebot_feedback_total{signal=\"like\"}[1h])) + sum(increase(cinebot_feedback_total{signal=\"dislike\"}[1h])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "green", "value": 0.75 }
            ]
          }
        }
      }
    }
  ]
}
