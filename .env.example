# ─────────────────────────────────────────────────────────────
# CineBot environment — copy to .env and fill in secrets.
# Never commit .env. Secrets live in a secrets manager in prod.
# ─────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────
APP_ENV=development                        # development | staging | production
APP_NAME=cinebot
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Auth ───────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string-in-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Postgres (pgvector) ────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=cinebot
POSTGRES_PASSWORD=cinebot_dev_password
POSTGRES_DB=cinebot
DATABASE_URL=postgresql+asyncpg://cinebot:cinebot_dev_password@postgres:5432/cinebot
SYNC_DATABASE_URL=postgresql://cinebot:cinebot_dev_password@postgres:5432/cinebot

# ── Redis ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_DB=1
REDIS_CELERY_BROKER=redis://redis:6379/2
REDIS_CELERY_BACKEND=redis://redis:6379/3

# ── Rate limiting ──────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# ── LLM toggle ─────────────────────────────────────────
# Providers: openai | ollama
LLM_PROVIDER=ollama
LLM_TIMEOUT_SECONDS=15
LLM_MAX_RETRIES=2

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.4

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TEMPERATURE=0.4

# ── Embeddings ─────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=64

# ── NLP models ─────────────────────────────────────────
INTENT_MODEL_PATH=/app/ml/models/intent_classifier
SPACY_MODEL=en_core_web_sm
INTENT_CONFIDENCE_THRESHOLD=0.60

# ── TMDB ───────────────────────────────────────────────
TMDB_API_KEY=                              # required: https://www.themoviedb.org/settings/api
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE=https://image.tmdb.org/t/p/w500
TMDB_INGEST_PAGES=50                       # ~1000 movies for dev

# ── Celery ─────────────────────────────────────────────
CELERY_TASK_ALWAYS_EAGER=false
CELERY_WORKER_CONCURRENCY=4

# ── Observability ──────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
PROMETHEUS_METRICS_PATH=/metrics

# ── Frontend ───────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
